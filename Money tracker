<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Talented Funds</title>

<meta name="theme-color" content="#8B5CF6">

<link rel="stylesheet" href="style.css">
<link rel="manifest" href="manifest.json">

<link rel="apple-touch-icon" href="assets/icon-192.png">
</head>

<body>

<div class="app">

<h1>💜 Talented Funds</h1>

<div class="card">

<h3>Current Balance</h3>

<h2 id="balance">৳0</h2>

</div>

<div class="card">

<h3>This Month</h3>

<p id="incomeTotal">
Income: ৳0
</p>

<p id="expenseTotal">
Expenses: ৳0
</p>

</div>

<div class="funds">

<div class="fund">

<h3>📦 Materials</h3>

<p id="materials">৳0</p>

<div class="bar">
<div id="materialsBar" class="fill"></div>
</div>

</div>

<div class="fund">

<h3>🚀 Business Growth</h3>

<p id="growth">৳0</p>

<div class="bar">
<div id="growthBar" class="fill"></div>
</div>

</div>

<div class="fund">

<h3>👤 Personal</h3>

<p id="personal">৳0</p>

<div class="bar">
<div id="personalBar" class="fill"></div>
</div>

</div>

</div>

<div class="buttons">

<button onclick="showIncome()">
➕ Add Income
</button>

<button onclick="showExpense()">
➖ Add Expense
</button>

</div>

<button class="undoBtn" onclick="undoLast()">
↩️ Undo Last Transaction
</button>

<div id="incomeBox" class="popup hidden">

<h2>Add Income</h2>

<input
id="incomeAmount"
type="number"
placeholder="Amount">

<button onclick="addIncome()">
Save
</button>

</div>

<div id="expenseBox" class="popup hidden">

<h2>Add Expense</h2>

<input
id="expenseAmount"
type="number"
placeholder="Amount">

<select id="expenseType">

<option>Materials</option>

<option>Business Growth</option>

<option>Personal</option>

</select>

<button onclick="addExpense()">
Save
</button>

</div>

<h2>History</h2>

<div id="history"></div>

</div>

<script src="script.js"></script>

</body>
</html>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",sans-serif;
}

body{
background:#121212;
color:#fff;
display:flex;
justify-content:center;
padding:25px 15px;
min-height:100vh;
}

.app{
width:100%;
max-width:430px;
}

h1{
font-size:34px;
margin-bottom:20px;
font-weight:700;
}

h2{
margin-top:20px;
margin-bottom:15px;
}

.card{
background:#7C3AED;
padding:24px;
border-radius:24px;
margin-bottom:18px;
box-shadow:0 12px 30px rgba(124,58,237,.35);
}

.card h3{
font-size:16px;
opacity:.85;
}

.card h2{
margin-top:8px;
font-size:40px;
}

.card p{
margin-top:8px;
font-size:17px;
}

.funds{
display:grid;
gap:15px;
margin-bottom:20px;
}

.fund{
background:#1D1D1D;
padding:20px;
border-radius:20px;
border:1px solid rgba(255,255,255,.06);
}

.fund h3{
margin-bottom:8px;
font-size:18px;
}

.fund p{
font-size:30px;
font-weight:700;
color:#B983FF;
}

.bar{
height:10px;
background:#303030;
border-radius:100px;
overflow:hidden;
margin-top:12px;
}

.fill{
height:100%;
width:0%;
background:#8B5CF6;
transition:.35s;
}

.buttons{
display:flex;
gap:12px;
margin-bottom:12px;
}

button{
width:100%;
padding:15px;
border:none;
border-radius:18px;
background:#8B5CF6;
color:#fff;
font-size:16px;
font-weight:600;
cursor:pointer;
transition:.2s;
}

button:active{
transform:scale(.98);
}

.undoBtn{
margin-bottom:20px;
background:#444;
}

.popup{
background:#1D1D1D;
padding:20px;
border-radius:20px;
margin-bottom:20px;
animation:fade .25s;
}

.hidden{
display:none;
}

input,
select{
width:100%;
padding:15px;
margin-top:15px;
margin-bottom:15px;
background:#2A2A2A;
border:none;
border-radius:15px;
color:white;
font-size:16px;
}

input:focus,
select:focus{
outline:2px solid #8B5CF6;
}

#history{
display:flex;
flex-direction:column;
gap:12px;
margin-top:10px;
padding-bottom:40px;
}

.historyItem{
display:flex;
justify-content:space-between;
align-items:center;
padding:16px;
background:#1D1D1D;
border-radius:16px;
}

.income{
border-left:5px solid #22C55E;
}

.expense{
border-left:5px solid #EF4444;
}

@keyframes fade{

from{
opacity:0;
transform:translateY(10px);
}

to{
opacity:1;
transform:translateY(0);
}

}

@media(max-width:430px){

.card h2{
font-size:34px;
}

.fund p{
font-size:26px;
}

}
// ---------- SETTINGS ----------

const MATERIALS_PERCENT = 0.45;
const GROWTH_PERCENT = 0.25;
const PERSONAL_PERCENT = 0.30;

// ---------- DATA ----------

let balance = Number(localStorage.getItem("balance")) || 0;
let materials = Number(localStorage.getItem("materials")) || 0;
let growth = Number(localStorage.getItem("growth")) || 0;
let personal = Number(localStorage.getItem("personal")) || 0;

let history =
JSON.parse(localStorage.getItem("history")) || [];

// ---------- SAVE ----------

function save(){

localStorage.setItem("balance",balance);
localStorage.setItem("materials",materials);
localStorage.setItem("growth",growth);
localStorage.setItem("personal",personal);

localStorage.setItem(
"history",
JSON.stringify(history)
);

}

// ---------- REFRESH ----------

function refresh(){

document.getElementById("balance").innerText =
"৳" + balance.toFixed(0);

document.getElementById("materials").innerText =
"৳" + materials.toFixed(0);

document.getElementById("growth").innerText =
"৳" + growth.toFixed(0);

document.getElementById("personal").innerText =
"৳" + personal.toFixed(0);

drawHistory();
updateStats();
updateBars();

save();

}

// ---------- POPUPS ----------

function showIncome(){

document.getElementById("incomeBox")
.classList.remove("hidden");

document.getElementById("expenseBox")
.classList.add("hidden");

}

function showExpense(){

document.getElementById("expenseBox")
.classList.remove("hidden");

document.getElementById("incomeBox")
.classList.add("hidden");

}

